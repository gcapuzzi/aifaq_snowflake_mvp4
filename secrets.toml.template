# .streamlit/secrets.toml
# Crea questa cartella e file nella root del progetto
# NON committare questo file su git

[snowflake]
account   = "your-account-identifier"   # es. "abc12345.eu-west-1"
user      = "your-username"
password  = "your-password"
warehouse = "COMPUTE_WH"
role      = "SYSADMIN"                  # opzionale
